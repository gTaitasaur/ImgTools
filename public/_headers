# Cloudflare Pages Caching Headers
# ────────────────────────────────────────────────────────────────
# Pixetide — Configuración de caché para máximo rendimiento y SEO.

# 1. Assets estáticos (JS, CSS, Imágenes, Fuentes, WASM)
# Los nombres de archivo incluyen hashes (ej: index-B0yA96hg.js), por lo que
# son inmutables. Los cacheamos agresivamente por 1 año.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# 2. Archivos HTML (Rutas del sitio)
# Queremos que carguen rápido pero Google debe ver cambios en meta tags
# inmediatamente cuando hagamos un nuevo build.
/*
  Cache-Control: public, max-age=0, must-revalidate

# 3. Sitemap y Robots
/sitemap.xml
  Cache-Control: public, max-age=0, must-revalidate
/robots.txt
  Cache-Control: public, max-age=0, must-revalidate
